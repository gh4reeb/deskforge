{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DeskForge",
  "version": "0.1.0",
  "identifier": "com.deskforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "category": "Productivity",
    "shortDescription": "AI Desktop Agent",
    "longDescription": "Local AI agent for desktop automation",
    "copyright": "",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": ""
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "sidecar": {
        "python-backend": {
          "cmd": "python",
          "args": ["../agent-backend/run.py"]
        }
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "DeskForge",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
